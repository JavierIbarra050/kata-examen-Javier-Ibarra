{
    "name": "deg540/examen-javier-ibarra-php",
    "description": "examen Javir Ibarra in PHP",
    "type": "project",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Deg540\\ExamenJavierIbarra\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deg540\\ExamenJavierIbarra\\Test\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "test": [
            "phpunit --configuration phpunit.xml"
        ]
    }
}
